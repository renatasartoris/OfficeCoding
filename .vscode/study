function BibleExplorerView() {
  const [searchTerm, setSearchTerm] = useState("");
  const [selectedTestament, setSelectedTestament] = useState("Novo Testamento");
  const defaultBook = useMemo(() => flatBooks.find((book) => book.name === "Marcos") || flatBooks[0], []);
  const [selectedBook, setSelectedBook] = useState(defaultBook);
  const [selectedChapter, setSelectedChapter] = useState(1);
  const [verseRange, setVerseRange] = useState({ start: 1, end: 6 });
  const [highlightsByVerse, setHighlightsByVerse] = useState({});
  const [selectionState, setSelectionState] = useState({ verseKey: null, text: "", color: "yellow", x: 0, y: 0, start: null, end: null });
  const [noteDrafts, setNoteDrafts] = useState({});
  const [noteModeVerseKey, setNoteModeVerseKey] = useState(null);
  const readerRef = useRef(null);
  const verseRefs = useRef({});

  useEffect(() => {
    const first = bibleBooks.find((group) => group.testament === selectedTestament)?.books?.[0];
    if (first && selectedBook.testament !== selectedTestament) {
      setSelectedBook({ ...first, testament: selectedTestament });
      setSelectedChapter(1);
    }
  }, [selectedTestament, selectedBook]);

  const filteredGroups = useMemo(() => {
    return bibleBooks
      .map((group) => ({
        ...group,
        books: group.books.filter((book) => `${book.name} ${group.testament}`.toLowerCase().includes(searchTerm.toLowerCase())),
      }))
      .filter((group) => group.books.length > 0);
  }, [searchTerm]);

  const chapterText = useMemo(() => getChapterText(selectedBook.name, selectedChapter), [selectedBook.name, selectedChapter]);
  const chapterButtons = useMemo(() => Array.from({ length: selectedBook.chapters }, (_, i) => i + 1), [selectedBook]);
  const verseNumbers = useMemo(() => chapterText.map((verse) => verse.verse), [chapterText]);

  useEffect(() => {
    const firstVerse = verseNumbers[0] || 1;
    const lastVerse = verseNumbers[Math.min(verseNumbers.length - 1, 5)] || firstVerse;
    setVerseRange({ start: firstVerse, end: Math.max(firstVerse, lastVerse) });
    setSelectionState((prev) => ({ ...prev, verseKey: null, text: "", start: null, end: null }));
    setNoteModeVerseKey(null);
  }, [selectedBook.name, selectedChapter, verseNumbers]);

  useEffect(() => {
    const timer = window.setTimeout(() => {
      readerRef.current?.scrollIntoView({ behavior: "smooth", block: "start" });
    }, 60);
    return () => window.clearTimeout(timer);
  }, [selectedBook.name, selectedChapter]);

  useEffect(() => {
    const clearSelection = () => {
      const current = window.getSelection?.();
      if (!current || current.toString().trim()) return;
      setSelectionState((prev) => ({ ...prev, verseKey: null, text: "", start: null, end: null }));
      setNoteModeVerseKey(null);
    };
    document.addEventListener("selectionchange", clearSelection);
    return () => document.removeEventListener("selectionchange", clearSelection);
  }, []);

  const visibleVerses = useMemo(() => {
    const maxVerse = verseNumbers[verseNumbers.length - 1] || 1;
    const normalizedStart = Math.max(1, Math.min(verseRange.start, maxVerse));
    const normalizedEnd = Math.max(normalizedStart, Math.min(verseRange.end, maxVerse));
    return chapterText.filter((verse) => verse.verse >= normalizedStart && verse.verse <= normalizedEnd);
  }, [chapterText, verseNumbers, verseRange]);

  const filteredBooksForTestament = useMemo(() => {
    return (filteredGroups.find((group) => group.testament === selectedTestament)?.books || []).map((book) => ({ ...book, testament: selectedTestament }));
  }, [filteredGroups, selectedTestament]);

  const clearToolbar = () => {
    setSelectionState((prev) => ({ ...prev, verseKey: null, text: "", start: null, end: null }));
    setNoteModeVerseKey(null);
    window.getSelection?.()?.removeAllRanges();
  };

  const saveHighlight = (colorOverride, withNote = false) => {
    const verseKey = selectionState.verseKey;
    const selectedText = selectionState.text.trim();
    if (!verseKey || !selectedText || selectionState.start == null || selectionState.end == null) return;
    const color = colorOverride || selectionState.color;
    setHighlightsByVerse((prev) => ({
      ...prev,
      [verseKey]: [
        ...(prev[verseKey] || []),
        {
          text: selectedText,
          start: selectionState.start,
          end: selectionState.end,
          color,
          note: withNote ? noteDrafts[verseKey] || "" : "",
        },
      ],
    }));
    setNoteDrafts((prev) => ({ ...prev, [verseKey]: withNote ? "" : prev[verseKey] || "" }));
    clearToolbar();
  };

  const removeHighlight = (verseKey, index) => {
    setHighlightsByVerse((prev) => ({
      ...prev,
      [verseKey]: (prev[verseKey] || []).filter((_, itemIndex) => itemIndex !== index),
    }));
  };

  const getTextOffset = (container, targetNode, targetOffset) => {
    if (!container || !targetNode) return 0;
    const walker = document.createTreeWalker(container, NodeFilter.SHOW_TEXT);
    let currentOffset = 0;
    let node = walker.nextNode();
    while (node) {
      if (node === targetNode) {
        return currentOffset + targetOffset;
      }
      currentOffset += node.textContent?.length || 0;
      node = walker.nextNode();
    }
    return currentOffset;
  };

  const selectVerseText = (verseKey) => {
    const selection = window.getSelection?.();
    const container = verseRefs.current[verseKey];
    if (!selection || selection.rangeCount === 0 || !container) return;
    const selectedText = selection.toString().trim();
    if (!selectedText) return;
    const range = selection.getRangeAt(0);
    const common = range.commonAncestorContainer;
    if (!container.contains(common.nodeType === 3 ? common.parentNode : common)) return;
    const rect = range.getBoundingClientRect();
    const start = getTextOffset(container, range.startContainer, range.startOffset);
    const end = getTextOffset(container, range.endContainer, range.endOffset);
    if (end <= start) return;
    setSelectionState((prev) => ({
      ...prev,
      verseKey,
      text: selectedText,
      x: rect.left + rect.width / 2,
      y: rect.top - 18,
      start,
      end,
    }));
    setNoteModeVerseKey(null);
  };

  return (
    <div className="space-y-6">
      <TopBar
        title="Bíblia"
        subtitle="Selecione um trecho e a barra de destaque aparece perto da seleção, enquanto a leitura sobe automaticamente para evitar rolagem cansativa."
        breadcrumbs={["Bíblia"]}
        actions={
          <>
            <div className="inline-flex items-center gap-2 rounded-full border border-amber-100 bg-amber-50 px-4 py-2 text-sm font-semibold text-amber-700"><Highlighter className="h-4 w-4" /> destaque flutuante</div>
            <div className="inline-flex items-center gap-2 rounded-full border border-rose-100 bg-rose-50 px-4 py-2 text-sm font-semibold text-rose-600"><StickyNote className="h-4 w-4" /> nota por trecho</div>
          </>
        }
      />

      <AnimatePresence>
        {selectionState.verseKey && selectionState.text && (
          <motion.div
            initial={{ opacity: 0, y: 6, scale: 0.94 }}
            animate={{ opacity: 1, y: 0, scale: 1 }}
            exit={{ opacity: 0, y: 6, scale: 0.94 }}
            transition={{ duration: 0.18 }}
            className="fixed z-50"
            style={{ left: selectionState.x, top: selectionState.y, transform: "translate(-50%, -100%)" }}
          >
            <div className="flex items-center gap-2 rounded-full border border-slate-200/70 bg-white/95 px-3 py-2 shadow-[0_24px_60px_-20px_rgba(15,23,42,0.38)] backdrop-blur-xl">
              <button type="button" onClick={() => saveHighlight(selectionState.color, noteModeVerseKey === selectionState.verseKey)} className="inline-flex h-9 w-9 items-center justify-center rounded-full bg-slate-900 text-white transition hover:scale-105" aria-label="Aplicar destaque">
                <Highlighter className="h-4 w-4" />
              </button>
              {Object.keys(highlightColors).map((color) => (
                <button
                  key={color}
                  type="button"
                  onClick={() => setSelectionState((prev) => ({ ...prev, color }))}
                  className={cn(
                    "h-8 w-8 rounded-full ring-2 ring-offset-2 transition hover:scale-105",
                    color === "yellow" && "bg-amber-300",
                    color === "pink" && "bg-pink-300",
                    color === "blue" && "bg-sky-300",
                    color === "green" && "bg-emerald-300",
                    color === "purple" && "bg-violet-300",
                    selectionState.color === color ? "ring-slate-900" : "ring-transparent"
                  )}
                  aria-label={`Selecionar cor ${color}`}
                />
              ))}
              <button type="button" onClick={() => setNoteModeVerseKey((prev) => prev === selectionState.verseKey ? null : selectionState.verseKey)} className={cn("inline-flex h-9 w-9 items-center justify-center rounded-full transition", noteModeVerseKey === selectionState.verseKey ? "bg-rose-100 text-rose-600" : "bg-slate-100 text-slate-600 hover:bg-slate-200")} aria-label="Adicionar anotação">
                <StickyNote className="h-4 w-4" />
              </button>
              <button type="button" onClick={clearToolbar} className="inline-flex h-9 w-9 items-center justify-center rounded-full bg-slate-100 text-slate-500 transition hover:bg-slate-200" aria-label="Cancelar seleção">
                <ArrowLeft className="h-4 w-4" />
              </button>
            </div>
          </motion.div>
        )}
      </AnimatePresence>

      <div className="grid gap-6 xl:grid-cols-[1.1fr_0.9fr]">
        <GlassCard className="p-5 md:p-6">
          <SectionTitle eyebrow="Catálogo bíblico" title="Livros, capítulos e versículos" description={`Todos os 66 livros e ${totalBibleChapters} capítulos estão disponíveis nesta prévia.`} />
          <div className="mt-5 flex flex-wrap gap-2">
            {bibleBooks.map((group) => (
              <button key={group.testament} onClick={() => setSelectedTestament(group.testament)} className={cn("rounded-full px-4 py-2 text-sm font-semibold transition", selectedTestament === group.testament ? "bg-slate-900 text-white" : "bg-slate-100 text-slate-700 hover:bg-slate-200")}>{group.testament}</button>
            ))}
          </div>
          <div className="relative mt-5">
            <Search className="absolute left-4 top-1/2 h-4 w-4 -translate-y-1/2 text-slate-400" />
            <input value={searchTerm} onChange={(e) => setSearchTerm(e.target.value)} placeholder="Buscar livro..." className="w-full rounded-2xl border border-rose-100 bg-white/90 py-3 pl-11 pr-4 outline-none" />
