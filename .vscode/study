function cn(...classes) {
  return classes.filter(Boolean).join(" ");
}

function createGeneratedChapter(bookName, chapter) {
  return Array.from({ length: 12 }, (_, index) => ({
    verse: index + 1,
    text: `${bookName} ${chapter}:${index + 1} · Conteúdo ilustrativo do leitor bíblico para navegação de capítulos e versículos nesta prévia interativa.`,
  }));
}

function getChapterText(bookName, chapter) {
  return localChapterSeeds[`${bookName}-${chapter}`] || createGeneratedChapter(bookName, chapter);
}

function escapeRegExp(value) {
  return value.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
}

function renderHighlightedContent(text, highlights, verseKey) {
  if (!highlights || highlights.length === 0) return text;
  const normalized = highlights
    .map((item, index) => {
      if (typeof item.start === "number" && typeof item.end === "number") {
        return {
          start: Math.max(0, item.start),
          end: Math.min(text.length, item.end),
          id: `${verseKey}-${index}-${item.start}`,
          color: item.color,
        };
      }
      if (!item.text) return null;
      const start = text.toLowerCase().indexOf(item.text.toLowerCase());
      if (start === -1) return null;
      return {
        start,
        end: start + item.text.length,
        id: `${verseKey}-${index}-${start}`,
        color: item.color,
      };
    })
    .filter(Boolean)
    .sort((a, b) => a.start - b.start || b.end - a.end);

  const filtered = [];
  let lastEnd = -1;
  normalized.forEach((match) => {
    if (match.start >= lastEnd) {
      filtered.push(match);
      lastEnd = match.end;
    }
  });

  if (filtered.length === 0) return text;

  const parts = [];
  let cursor = 0;
  filtered.forEach((match) => {
    if (match.start > cursor) parts.push(text.slice(cursor, match.start));
    parts.push(
      <mark key={match.id} className={cn("rounded px-1 py-0.5 ring-1", highlightColors[match.color] || highlightColors.yellow)}>
        {text.slice(match.start, match.end)}
      </mark>,
    );
    cursor = match.end;
  });
  if (cursor < text.length) parts.push(text.slice(cursor));
  return parts;
}

