                                        <div className="space-y-3 p-4">
                                          <textarea value={field.answer} onChange={(e) => setQuestionFields((prev) => ({ ...prev, [week.week]: prev[week.week].map((item, itemIdx) => itemIdx === idx ? { ...item, answer: e.target.value } : item) }))} placeholder="Resposta / desenvolvimento" className="min-h-[88px] w-full rounded-2xl border border-rose-100 bg-white px-4 py-3 text-sm text-slate-700 outline-none" />
                                          <textarea value={field.notes} onChange={(e) => setQuestionFields((prev) => ({ ...prev, [week.week]: prev[week.week].map((item, itemIdx) => itemIdx === idx ? { ...item, notes: e.target.value } : item) }))} placeholder="Anotações" className="min-h-[72px] w-full rounded-2xl border border-rose-100 bg-white px-4 py-3 text-sm text-slate-700 outline-none" />
                                          <input value={field.references} onChange={(e) => setQuestionFields((prev) => ({ ...prev, [week.week]: prev[week.week].map((item, itemIdx) => itemIdx === idx ? { ...item, references: e.target.value } : item) }))} placeholder="Referências bíblicas ou observações extras" className="w-full rounded-2xl border border-rose-100 bg-white px-4 py-3 text-sm text-slate-700 outline-none" />
                                        </div>
                                      </motion.div>
                                    )}
                                  </AnimatePresence>
                                </motion.div>
                              );
                            })}
