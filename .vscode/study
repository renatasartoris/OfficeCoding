                          <div className="mt-4 rounded-[1.35rem] border border-slate-100 bg-white/92 p-4 shadow-sm">
                            <div className="mb-2 flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.18em] text-slate-400"><StickyNote className="h-3.5 w-3.5" /> anotação do trecho selecionado</div>
                            <div className="rounded-2xl border border-slate-100 bg-slate-50 px-4 py-3 text-sm font-medium text-slate-700">{selectedSnippet}</div>
                            <textarea
                              value={noteDrafts[verseKey] || ""}
                              onChange={(e) => setNoteDrafts((prev) => ({ ...prev, [verseKey]: e.target.value }))}
                              placeholder="Escreva uma anotação sobre esse trecho destacado..."
                              className="mt-3 min-h-[92px] w-full rounded-2xl border border-rose-100 bg-white px-4 py-3 text-sm text-slate-700 outline-none"
                            />
                            <div className="mt-3 flex justify-end">
                              <button type="button" onClick={() => saveHighlight(selectionState.color, true)} className="rounded-2xl bg-slate-900 px-4 py-3 text-sm font-semibold text-white transition hover:translate-y-[-1px]">salvar com anotação</button>
                            </div>
                          </div>
                        </motion.div>
                      )}
                    </AnimatePresence>

                    {highlights.length > 0 && (
                      <div className="mt-4 space-y-3">
                        <div className="text-xs font-bold uppercase tracking-[0.18em] text-slate-400">Destaques deste verso</div>
                        {highlights.map((item, index) => (
                          <div key={`${verseKey}-${index}`} className="flex flex-col gap-3 rounded-[1.25rem] border border-slate-100 bg-white/88 p-4 md:flex-row md:items-start md:justify-between">
                            <div className="min-w-0">
                              <div className="flex flex-wrap items-center gap-2">
                                <span className={cn("rounded-full px-3 py-1 text-xs font-semibold ring-1", highlightColors[item.color] || highlightColors.yellow)}>{item.color}</span>
                                <span className="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">{item.text}</span>
                              </div>
                              {item.note && <p className="mt-3 text-sm leading-6 text-slate-600">{item.note}</p>}
                            </div>
                            <button type="button" onClick={() => removeHighlight(verseKey, index)} className="rounded-full bg-slate-100 px-3 py-1.5 text-xs font-semibold text-slate-600 transition hover:bg-slate-200">remover</button>
                          </div>
                        ))}
                      </div>
                    )}
                  </motion.div>
                );
              })}
            </div>
          </GlassCard>
        </div>
      </div>
    </div>
  );
}

function SearchView() {
  const [query, setQuery] = useState("");
  const results = useMemo(() => {
    if (!query) return [];
    const lower = query.toLowerCase();
    const fromBooks = flatBooks.filter((book) => book.name.toLowerCase().includes(lower)).slice(0, 8).map((book) => ({ type: "Livro", title: book.name, subtitle: `${book.chapters} capítulos · ${book.testament}` }));
    const fromNotes = studyNotes.filter((note) => `${note.title} ${note.reference} ${note.content}`.toLowerCase().includes(lower)).map((note) => ({ type: "Nota", title: note.title, subtitle: note.reference }));
    const fromBookmarks = bookmarks.filter((item) => `${item.reference} ${item.text}`.toLowerCase().includes(lower)).map((item) => ({ type: "Verso salvo", title: item.reference, subtitle: item.text }));
    return [...fromBooks, ...fromNotes, ...fromBookmarks].slice(0, 12);
  }, [query]);

  return (
    <div className="space-y-6">
      <TopBar title="Buscar" subtitle="Pesquisa transversal entre livros, notas e versos salvos." breadcrumbs={["Buscar"]} />
      <SectionTitle eyebrow="Descoberta" title="Busca inteligente" description="Uma pesquisa rápida para estrutura bíblica, anotações e favoritos." />
      <GlassCard className="p-5 md:p-6">
        <div className="relative">
          <Search className="absolute left-4 top-1/2 h-5 w-5 -translate-y-1/2 text-slate-400" />
          <input value={query} onChange={(e) => setQuery(e.target.value)} placeholder="Ex.: amor, João, Romanos 8" className="w-full rounded-2xl border border-rose-100 bg-white/90 py-4 pl-12 pr-4 text-base outline-none" />
        </div>
      </GlassCard>
      <div className="grid gap-4 lg:grid-cols-2 xl:grid-cols-3">
        {results.length === 0 ? (
          <GlassCard className="p-8 lg:col-span-2 xl:col-span-3">
            <div className="flex items-center gap-3 text-slate-900"><Search className="h-5 w-5 text-violet-500" /><span className="font-semibold">Digite algo para começar</span></div>
            <p className="mt-2 text-sm text-slate-600">A busca desta prévia percorre livros, notas e favoritos.</p>
          </GlassCard>
        ) : (
          results.map((result, i) => (
            <motion.div key={`${result.type}-${result.title}-${i}`} initial={{ opacity: 0, y: 8 }} animate={{ opacity: 1, y: 0 }}>
              <GlassCard className="p-5" interactive>
                <div className="mb-3 flex items-center justify-between"><Pill tone={result.type === "Livro" ? "violet" : result.type === "Nota" ? "rose" : "amber"}>{result.type}</Pill><ChevronRight className="h-4 w-4 text-slate-400" /></div>
                <div className="font-bold text-slate-900">{result.title}</div>
                <div className="mt-2 text-sm leading-6 text-slate-600">{result.subtitle}</div>
              </GlassCard>
            </motion.div>
          ))
        )}
      </div>
    </div>
  );
}

function runPreviewSanityChecks() {
  if (readingPlans.length !== 2) throw new Error("Esperado exatamente 2 planos ativos.");
  if (!readingPlans.some((plan) => plan.type === "new-testament")) throw new Error("Plano do Novo Testamento ausente.");
  if (!weeklyPlan.every((week) => Array.isArray(week.questions) && week.questions.length > 0)) throw new Error("Cada semana deve possuir perguntas.");
  if (flatBooks.length !== 66) throw new Error("Esperado catálogo com 66 livros.");
}

runPreviewSanityChecks();

