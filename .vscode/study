function WeeklyPlanView({ onBack, onOpenBible }) {
  const [openWeek, setOpenWeek] = useState(5);
  const [studyWeeks, setStudyWeeks] = useState(weeklyPlan);
  const [questionFields, setQuestionFields] = useState(() => Object.fromEntries(weeklyPlan.map((week) => [week.week, week.questions.map(() => ({ answer: "", notes: "", references: "" }))])));
  const [openQuestions, setOpenQuestions] = useState(() => Object.fromEntries(weeklyPlan.map((week) => [week.week, null])));
  const [conclusions, setConclusions] = useState(() => Object.fromEntries(weeklyPlan.map((week) => [week.week, ""])));
  const [baseTextPreview, setBaseTextPreview] = useState(null);
  const [baseTextModalTop, setBaseTextModalTop] = useState(24);

  const totalMeetings = studyWeeks.length;
  const completedMeetings = studyWeeks.filter((week) => week.status === "concluído").length;
  const progress = Math.round((completedMeetings / totalMeetings) * 100);
  const statusTone = { pendente: "rose", "em andamento": "amber", concluído: "emerald" };

  const parseBaseReference = (reference) => {
    const normalized = reference.replace("–", "-");
    const pieces = normalized.split(" ");
    const chapterVerse = pieces.pop();
    const bookName = pieces.join(" ").trim();
    if (!chapterVerse || !bookName || chapterVerse.indexOf(":") === -1) return null;
    const chapterParts = chapterVerse.split(":");
    const chapter = Number(chapterParts[0]);
    const versePart = chapterParts[1] || "";
    const verseParts = versePart.split("-");
    const startVerse = Number(verseParts[0]);
    const endVerse = Number(verseParts[1] || verseParts[0]);
    if (!chapter || !startVerse || !endVerse) return null;
    return { bookName, chapter, startVerse, endVerse };
  };

  const openBaseTextCard = (reference, event) => {
    const viewportHeight = typeof window !== "undefined" ? window.innerHeight : 800;
    const triggerRect = event?.currentTarget?.getBoundingClientRect?.();
    const preferredTop = triggerRect ? triggerRect.top - 18 : viewportHeight * 0.18;
    const estimatedModalHeight = Math.min(viewportHeight - 24, 620);
    const maxTop = Math.max(12, viewportHeight - estimatedModalHeight - 12);
    const computedTop = Math.max(12, Math.min(preferredTop, maxTop));
    setBaseTextModalTop(computedTop);
    const parsed = parseBaseReference(reference);
    if (!parsed) {
      setBaseTextPreview({
        reference,
        verses: [{ verse: 1, text: "Prévia local para " + reference + "." }],
      });
      return;
    }
    const chapterVerses = getChapterText(parsed.bookName, parsed.chapter);
    const verses = chapterVerses.filter((item) => item.verse >= parsed.startVerse && item.verse <= parsed.endVerse);
    setBaseTextPreview({
      reference,
      verses: verses.length > 0 ? verses : [{ verse: parsed.startVerse, text: "Prévia local para " + reference + "." }],
    });
  };

  return (
    <div className="space-y-6">
      <TopBar
        title="Estudo Bíblico"
        subtitle="12 encontros semanais com perguntas, respostas, notas e conclusão por encontro."
        breadcrumbs={["Planos de estudo", "Estudo Bíblico"]}
        onBack={onBack}
        actions={
          <>
            <div className="inline-flex items-center gap-2 rounded-full border border-emerald-100 bg-emerald-50 px-4 py-2 text-sm font-semibold text-emerald-600"><Check className="h-4 w-4" /> {completedMeetings}/{totalMeetings} concluídos</div>
            <button onClick={onOpenBible} className="inline-flex items-center gap-2 rounded-full border border-violet-100 bg-violet-50 px-4 py-2 text-sm font-semibold text-violet-600"><Library className="h-4 w-4" /> abrir bíblia</button>
          </>
        }
      />

      <AnimatePresence>
        {baseTextPreview && (
          <motion.div initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }} className="fixed inset-0 z-50 flex items-start justify-center overflow-y-auto bg-slate-950/35 p-2 backdrop-blur-sm sm:p-4" onClick={() => setBaseTextPreview(null)}>
            <motion.div initial={{ opacity: 0, y: 14, scale: 0.96 }} animate={{ opacity: 1, y: 0, scale: 1 }} exit={{ opacity: 0, y: 14, scale: 0.96 }} transition={{ duration: 0.2 }} className="w-full max-w-2xl self-start overflow-hidden rounded-[2rem] border border-white/70 bg-white shadow-[0_30px_120px_-30px_rgba(15,23,42,0.35)] max-h-[calc(100dvh-1rem)]" style={{ marginTop: baseTextModalTop + 'px', marginBottom: '12px' }} onClick={(e) => e.stopPropagation()}>
              <div className="border-b border-slate-100 bg-gradient-to-br from-rose-50 via-fuchsia-50 to-violet-50 p-6">
                <div className="flex items-start justify-between gap-4">
                  <div>
                    <div className="text-xs font-bold uppercase tracking-[0.22em] text-rose-500">Texto base do encontro</div>
                    <div className="mt-2 text-2xl font-black tracking-tight text-slate-900">{baseTextPreview.reference}</div>
                    <p className="mt-2 text-sm leading-6 text-slate-500">A leitura abre em um card modal para não interromper o fluxo do estudo semanal.</p>
                  </div>
                  <button onClick={() => setBaseTextPreview(null)} className="rounded-full bg-white px-4 py-2 text-sm font-semibold text-slate-600 shadow-sm transition hover:bg-slate-50">fechar</button>
                </div>
              </div>
              <div className="space-y-3 overflow-y-auto p-4 sm:p-6 max-h-[calc(100dvh-12.5rem)]">
                {baseTextPreview.verses.map((item) => (
                  <div key={baseTextPreview.reference + "-" + item.verse} className="rounded-[1.35rem] border border-slate-100 bg-white p-4 shadow-sm">
                    <div className="mb-2 text-xs font-bold uppercase tracking-[0.2em] text-violet-500">Verso {item.verse}</div>
                    <p className="text-sm leading-8 text-slate-700">{item.text}</p>
                  </div>
                ))}
              </div>
            </motion.div>
          </motion.div>
        )}
      </AnimatePresence>

      <GlassCard className="overflow-hidden border border-violet-100 bg-gradient-to-br from-violet-50 via-pink-50 to-rose-50 p-8 text-slate-900">
        <SectionTitle eyebrow="Jornada" title="Plano de estudo em 12 encontros" description="Cada semana representa um encontro, com visão clara do progresso e conteúdo." />
        <div className="mt-6">
          <div className="mb-2 flex items-center justify-between text-sm font-semibold text-slate-600">
            <span>{completedMeetings} de {totalMeetings} encontros concluídos</span>
            <span>{progress}%</span>
          </div>
          <div className="h-3 rounded-full bg-white">
            <motion.div initial={{ width: 0 }} animate={{ width: `${progress}%` }} transition={{ duration: 1.2 }} className="h-3 rounded-full bg-gradient-to-r from-violet-300 via-pink-300 to-rose-300" />
          </div>
        </div>
      </GlassCard>

      <div className="space-y-4">
        {studyWeeks.map((week, i) => {
          const isOpen = openWeek === week.week;
          return (
            <motion.div key={week.week} initial={{ opacity: 0, y: 10 }} animate={{ opacity: 1, y: 0 }} transition={{ delay: i * 0.03 }}>
              <GlassCard className="overflow-hidden border border-rose-100 bg-white/90">
                <button onClick={() => setOpenWeek(isOpen ? -1 : week.week)} className="flex w-full items-center justify-between gap-4 p-5 text-left md:p-6">
                  <div className="min-w-0">
                    <div className="text-xs font-bold uppercase tracking-[0.22em] text-violet-500">Semana {week.week}</div>
                    <div className="mt-1 text-xl font-bold text-slate-900">{week.theme}</div>
                    <div className="mt-2 text-sm text-slate-500">Texto base para o estudo: <button className="font-semibold text-rose-600 underline decoration-2 hover:text-rose-700" onClick={(e) => { e.stopPropagation(); openBaseTextCard(week.baseText, e); }}>{week.baseText}</button></div>
                  </div>
                  <div className="flex items-center gap-3">
                    <Pill tone={statusTone[week.status]}>{week.status}</Pill>
                    <ChevronDown className={cn("h-5 w-5 text-slate-500 transition", isOpen && "rotate-180")} />
                  </div>
                </button>
                <AnimatePresence initial={false}>
                  {isOpen && (
                    <motion.div initial={{ height: 0, opacity: 0 }} animate={{ height: "auto", opacity: 1 }} exit={{ height: 0, opacity: 0 }} className="overflow-hidden border-t border-rose-100">
                      <div className="grid gap-4 p-4 md:p-5 xl:grid-cols-[1.2fr_0.8fr]">
                        <div className="rounded-[1.5rem] border border-rose-100 bg-gradient-to-br from-white to-rose-50 p-5">
                          <div className="mb-3 text-sm font-bold uppercase tracking-[0.18em] text-rose-500">Perguntas para reflexão</div>
                          <div className="space-y-3">
                            {week.questions.map((question, idx) => {
                              const field = questionFields[week.week]?.[idx] || { answer: "", notes: "", references: "" };
                              const isQuestionOpen = openQuestions[week.week] === idx;
                              return (
                                <motion.div whileHover={{ y: -2 }} key={idx} className="overflow-hidden rounded-[1.4rem] border border-white bg-white/95 shadow-sm">
                                  <button type="button" onClick={() => setOpenQuestions((prev) => ({ ...prev, [week.week]: prev[week.week] === idx ? null : idx }))} className="flex w-full items-center justify-between gap-4 p-4 text-left">
